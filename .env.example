# Shared
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cue_h0
CUE_WORKSPACE_SLUG=cue-h0

# Web
NEXT_PUBLIC_CUE_DEMO_WORKSPACE=cue-h0
CUE_DEMO_CONNECTORS_CONNECTED=true
CUE_DEMO_MODE=hybrid
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Optional agentic synthesis and external search
OPENAI_API_KEY=
CUE_MODEL=gpt-5-mini
NODE_OPTIONS=--dns-result-order=ipv4first
EXA_API_KEY=

# Optional Slack bot
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...
SLACK_SOCKET_MODE=true
SLACK_LAUNCH_CHANNEL_ID=C0123456789

# Connector credentials
GITHUB_TOKEN=ghp_...
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
LINEAR_API_KEY=lin_api_...
LINEAR_TEAM_ID=...
NOTION_TOKEN=secret_...
POSTHOG_API_KEY=phx_...
VERCEL_TOKEN=...
VERCEL_PROJECT_ID=...
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
